---
import BaseLayout from '../layouts/BaseLayout.astro';
const CALENDLY = 'https://calendly.com/annawootenofficial';
---
<BaseLayout title="Live Classes — Anna Wooten" description="Weekly live Zoom classes: Transformative Breathwork and Women's Group, every Tuesday.">
  <nav class="nav">
    <a href="/" class="nav-logo">Anna Wooten</a>
    <div class="nav-links">
      <a href="/about">About</a>
      <a href="/work-with-me">Work With Me</a>
      <a href="/classes" style="color: var(--gold)">Classes</a>
      <a href="/products">Products</a>
      <a href="/events">Events</a>
    </div>
    <a href="#" onclick={`Calendly.initPopupWidget({url: '${CALENDLY}'});return false;`} class="nav-cta">Book a Consultation</a>
  </nav>

  <div class="page-hero">
    <p class="section-tag">Live Online &bull; Every Tuesday</p>
    <h1>Group Classes</h1>
    <p>Weekly Zoom classes designed to support nervous system regulation, subconscious awareness, and personal growth in a structured group setting.</p>
  </div>

  <!-- Breathwork Class -->
  <section class="class-section">
    <div class="container">
      <div class="class-grid">
        <div class="class-info">
          <p class="section-tag">Tuesday Evenings</p>
          <h2>Transformative Breathwork</h2>
          <div class="divider"><span></span><span class="diamond">&#10022;</span><span></span></div>
          <p>A guided breathwork experience using Biodynamic Breathwork and Trauma Release techniques. Through conscious breathing and body awareness, participants explore the connection between breath, the nervous system, and subconscious emotional patterns.</p>
          <p>These sessions focus on regulation, release of stored tension, and deeper embodiment.</p>
          <div class="class-meta">
            <div class="meta-row"><span class="meta-label">Schedule</span><span>Tuesdays &bull; 6:00–7:15 PM CST</span></div>
            <div class="meta-row"><span class="meta-label">Format</span><span>Live Zoom</span></div>
            <div class="meta-row"><span class="meta-label">Drop-in</span><span class="price-text">$40</span></div>
            <div class="meta-row"><span class="meta-label">Monthly</span><span class="price-text">$129 / month</span></div>
          </div>
          <a href="#" class="btn btn-gold">Enroll Now</a>
        </div>
       <div class="class-visual bw-visual" style="background-image: url('/IMG_2992 (2).jpeg'); background-size: cover; background-position: center top;">
          <div class="visual-label">Breathwork</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Women's Group -->
  <section class="class-section alt">
    <div class="container">
      <div class="class-grid reverse">
      <div class="class-visual wg-visual" style="background-image: url('/IMG_9796.JPG'); background-size: cover; background-position: center;">
          <div class="visual-label">Women's Group</div>
        </div>
        <div class="class-info">
          <p class="section-tag">Tuesday Evenings</p>
          <h2>Women's Group</h2>
          <div class="divider"><span></span><span class="diamond">&#10022;</span><span></span></div>
          <p>A facilitated weekly group designed for deeper emotional awareness, reflection, and connection among women. This space combines guided discussion, meditation, sensuality, empowerment, and reflective practices.</p>
          <p>The group setting allows participants to witness and be witnessed — offering insight, accountability, and support within a consistent and supportive community container.</p>
          <div class="class-meta">
            <div class="meta-row"><span class="meta-label">Schedule</span><span>Tuesdays &bull; 7:30–9:00 PM CST</span></div>
            <div class="meta-row"><span class="meta-label">Format</span><span>Live Zoom</span></div>
            <div class="meta-row"><span class="meta-label">Monthly</span><span class="price-text">$149 / month</span></div>
          </div>
          <a href="#" class="btn btn-gold">Enroll Now</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Combined offer -->
  <section class="combo-section">
    <div class="container">
      <div class="combo-card">
        <span class="combo-badge">Best Value</span>
        <p class="section-tag center">Attend Both Classes</p>
        <h2>Combined Membership</h2>
        <div class="divider center"><span></span><span class="diamond">&#10022;</span><span></span></div>
        <p>Women who participate in both Transformative Breathwork and Women's Group receive a combined monthly membership rate.</p>
        <div class="combo-price">$229 <span>/ month</span></div>
        <p class="combo-save">Save $49 compared to enrolling separately</p>
        <a href="#" class="btn btn-gold">Enroll in Both</a>
      </div>
    </div>
  </section>

  <!-- Newsletter Popup -->
  <div id="newsletter-popup" class="popup-overlay" role="dialog" aria-modal="true">
    <div class="popup-card">
      <button class="popup-close" id="popup-close-btn" aria-label="Close">&times;</button>
      <p class="section-tag center">Stay Connected</p>
      <h2 class="popup-title">Join the Circle</h2>
      <div class="divider center"><span></span><span class="diamond">&#10022;</span><span></span></div>
      <p class="popup-desc">Get updates on upcoming classes, events, and offerings from Anna.</p>
      <form name="newsletter" method="POST" data-netlify="true" class="popup-form" id="popup-form">
        <input type="hidden" name="form-name" value="newsletter" />
        <input type="email" name="email" placeholder="Your email address" required class="popup-input" />
        <button type="submit" class="btn btn-gold">Subscribe</button>
      </form>
      <p class="popup-note">No spam, ever. Unsubscribe anytime.</p>
    </div>
  </div>

  <script is:inline>
    function closePopup() {
      var popup = document.getElementById('newsletter-popup');
      if (popup) popup.classList.remove('popup-visible');
    }

    document.getElementById('popup-close-btn').addEventListener('click', closePopup);

    document.getElementById('newsletter-popup').addEventListener('click', function(e) {
      if (e.target === this) closePopup();
    });

    document.getElementById('popup-form').addEventListener('submit', function(e) {
      e.preventDefault();
      var form = this;
      fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(new FormData(form)).toString()
      }).then(function() {
        form.innerHTML = '<p class="popup-success">Thank you! You're on the list.</p>';
      }).catch(function() {
        form.innerHTML = '<p class="popup-success">Thank you! You're on the list.</p>';
      });
    });

    var seen = localStorage.getItem('newsletterSeen');
    var now = Date.now();
    if (!seen || now - parseInt(seen) > 7 * 24 * 60 * 60 * 1000) {
      setTimeout(function() {
        document.getElementById('newsletter-popup').classList.add('popup-visible');
        localStorage.setItem('newsletterSeen', now.toString());
      }, 3000);
    }
  </script>
  <footer class="footer">
    <p>&copy; {new Date().getFullYear()} Anna Wooten. All rights reserved.</p>
  </footer>
</BaseLayout>

<style>
  .class-section { padding: 7rem 0; }
  .class-section.alt { background: rgba(255,255,255,0.02); }
  .class-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 5rem; align-items: center; }
  .class-grid.reverse { direction: rtl; }
  .class-grid.reverse > * { direction: ltr; }
  .class-info h2 { font-size: clamp(2rem, 3.5vw, 2.8rem); margin-bottom: 0.25rem; }
  .class-info p { color: var(--muted); line-height: 1.85; margin-bottom: 1rem; }
  .class-meta { margin: 2rem 0; border: 1px solid var(--card-border); border-radius: 12px; overflow: hidden; }
  .meta-row { display: flex; justify-content: space-between; align-items: center; padding: 0.9rem 1.4rem; border-bottom: 1px solid var(--card-border); font-size: 0.88rem; }
  .meta-row:last-child { border-bottom: none; }
  .meta-label { color: var(--gold); font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; }
  .price-text { color: var(--gold); font-family: var(--font-display); font-size: 1.2rem; }
  .class-visual { border-radius: 14px; aspect-ratio: 4/5; display: flex; align-items: flex-end; padding: 2rem; }
  .bw-visual { background: linear-gradient(135deg, rgba(160,80,240,0.35) 0%, rgba(80,120,255,0.25) 100%); border: 1px solid var(--card-border); }
  .wg-visual { background: linear-gradient(135deg, rgba(232,150,10,0.2) 0%, rgba(200,80,140,0.25) 100%); border: 1px solid var(--card-border); }
  .visual-label { font-family: var(--font-display); font-size: 1.8rem; color: rgba(240,234,222,0.3); font-style: italic; }

  .combo-section { padding: 6rem 0; }
  .combo-card { max-width: 560px; margin: 0 auto; text-align: center; padding: 4rem 3rem; border: 1px solid var(--border); border-radius: 20px; background: rgba(232,150,10,0.06); position: relative; }
  .combo-badge { position: absolute; top: -0.8rem; left: 50%; transform: translateX(-50%); background: var(--gold); color: #0d0a1e; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; padding: 0.3rem 1.2rem; border-radius: 9999px; white-space: nowrap; }
  .combo-card h2 { font-size: 2.5rem; margin-bottom: 0.25rem; }
  .combo-card p { color: var(--muted); margin-bottom: 0.5rem; line-height: 1.8; }
  .combo-price { font-family: var(--font-display); font-size: 4rem; color: var(--gold); margin: 1.5rem 0 0.5rem; }
  .combo-price span { font-size: 1.5rem; color: var(--muted); }
  .combo-save { font-size: 0.82rem; color: var(--muted); margin-bottom: 2rem !important; }

  /* Newsletter popup */
  .popup-overlay { position: fixed; inset: 0; background: rgba(13,10,30,0.85); backdrop-filter: blur(10px); z-index: 999; display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.4s ease; padding: 1.5rem; }
  .popup-overlay.popup-visible { opacity: 1; pointer-events: all; }
  .popup-card { background: #16112e; border: 1px solid rgba(232,150,10,0.28); border-radius: 20px; padding: 3.5rem; max-width: 480px; width: 100%; text-align: center; position: relative; box-shadow: 0 0 60px rgba(160,80,240,0.2); }
  .popup-close { position: absolute; top: 1.2rem; right: 1.5rem; background: none; border: none; color: rgba(240,234,222,0.35); font-size: 1.8rem; cursor: pointer; line-height: 1; transition: color 0.2s; padding: 0; }
  .popup-close:hover { color: var(--gold); }
  .popup-title { font-size: 2.2rem; margin-bottom: 0.25rem; }
  .popup-desc { color: var(--muted); font-size: 0.95rem; line-height: 1.75; margin-bottom: 1.8rem; }
  .popup-form { display: flex; flex-direction: column; gap: 1rem; }
  .popup-input { background: rgba(255,255,255,0.05); border: 1px solid rgba(232,150,10,0.22); border-radius: 9999px; padding: 0.9rem 1.6rem; color: var(--text); font-family: var(--font-body); font-size: 0.88rem; outline: none; transition: border-color 0.3s; }
  .popup-input::placeholder { color: rgba(240,234,222,0.35); }
  .popup-input:focus { border-color: rgba(232,150,10,0.55); }
  .popup-note { font-size: 0.72rem; color: var(--muted); margin-top: 1rem; opacity: 0.55; }
  .popup-success { color: var(--gold); font-family: var(--font-display); font-size: 1.4rem; font-style: italic; padding: 1rem 0; }
  @media (max-width: 768px) {
    .class-section { padding: 5rem 0; }
    .class-grid, .class-grid.reverse { grid-template-columns: 1fr; direction: ltr; }
    .class-visual { aspect-ratio: 2/1; }
  }
</style>
