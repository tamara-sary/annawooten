---
import BaseLayout from '../layouts/BaseLayout.astro';

const CALENDLY = 'https://calendly.com/annawootenofficial';
---

<BaseLayout title="Anna Wooten — Integrative Wellness & Transformation">

  <nav class="nav">
    <a href="/" class="nav-logo">Anna Wooten</a>
    <div class="nav-links">
      <a href="/about">About</a>
      <a href="/work-with-me">Work With Me</a>
      <a href="/classes">Classes</a>
      <a href="/products">Products</a>
      <a href="/events">Events</a>
    </div>
    <a href="#" onclick={`Calendly.initPopupWidget({url: '${CALENDLY}'});return false;`} class="nav-cta">Book a Consultation</a>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <p class="section-tag">Integrative Wellness &amp; Transformation</p>
      <h1>Reconnect with yourself.<br /><em>Create lasting change.</em></h1>
      <p class="hero-desc">
        Personalized work with the subconscious mind, nervous system, and deeper self —
        supporting women who are ready for meaningful internal transformation.
      </p>
      <div class="hero-btns">
        <a href="#" onclick={`Calendly.initPopupWidget({url: '${CALENDLY}'});return false;`} class="btn btn-gold">Book a Free Consultation</a>
        <a href="/about" class="btn btn-outline">Meet Anna</a>
      </div>
    </div>
  </section>

  <!-- About Teaser -->
  <section class="about-teaser">
    <div class="container">
      <div class="about-teaser-grid">
        <div class="about-teaser-img">
          <img src="/anna.jpg" alt="Anna Wooten" />
        </div>
        <div class="about-teaser-text">
          <p class="section-tag">About the Guide</p>
          <h2>Anna Wooten</h2>
          <div class="divider"><span></span><span class="diamond">&#10022;</span><span></span></div>
          <p>
            Anna is an integrative practitioner, coach, and facilitator working at the intersection
            of the nervous system, the subconscious mind, and personal transformation. Her work
            blends breathwork, hypnosis, Reiki, sound healing, and intuitive guidance to support
            women in creating deep and lasting internal change.
          </p>
          <p>Anna is currently a graduate student in Clinical Mental Health Counseling at Naropa University.</p>
          <a href="/about" class="btn btn-outline" style="margin-top: 1.8rem;">Read Anna's Story</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 1:1 Package Feature -->
  <section class="feature-section">
    <div class="container">
      <div class="feature-inner">
        <p class="section-tag center">Primary Offering</p>
        <h2 class="section-title center">1:1 Transformation</h2>
        <div class="divider center"><span></span><span class="diamond">&#10022;</span><span></span></div>
        <p class="feature-desc">
          A personalized three-month container for women who want focused support and meaningful
          internal change. We work with the mind, body, and deeper intuitive layers of the self —
          exploring patterns, building awareness, and integrating new ways of relating to yourself.
        </p>
        <div class="feature-pillars">
          <div class="pillar">
            <span class="pillar-icon">&#10024;</span>
            <h4>Support Your Mind</h4>
            <p>Hypnosis &amp; meditation to access subconscious beliefs and emotional patterns</p>
          </div>
          <div class="pillar">
            <span class="pillar-icon">&#10024;</span>
            <h4>Support Your Body</h4>
            <p>Breathwork &amp; Reiki to regulate the nervous system and release stored tension</p>
          </div>
          <div class="pillar">
            <span class="pillar-icon">&#10024;</span>
            <h4>Support Your Soul</h4>
            <p>Intuitive guidance &amp; coaching for deeper self-understanding and personal direction</p>
          </div>
        </div>
        <p class="feature-detail">Sessions twice per month &bull; 60–75 minutes &bull; Three months</p>
        <a href="/work-with-me" class="btn btn-gold">Learn More &amp; Apply</a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="testimonials">
    <div class="testimonials-header">
      <p class="section-tag center">Kind Words</p>
      <h2 class="section-title center">What clients say</h2>
      <div class="divider center"><span></span><span class="diamond">&#10022;</span><span></span></div>
    </div>
    <div class="testimonials-track-wrap">
      <div class="testimonials-cols">

        <!-- Column 1 -->
        <div class="t-col">
          <div class="t-scroll t-scroll-1">
            <div class="t-card"><p class="t-quote">"Anna's sound healing and breathwork session was an absolute delight. She created a safe and nurturing space for each individual, allowing them to explore their inner selves. Before the sound bath, Anna guided us into a beautiful meditation, and she even incorporated breathwork into the session. While the breathwork was intense at times, it was an incredibly liberating experience. Overall, I highly recommend Anna's sessions to anyone seeking a spiritual journey."</p><p class="t-name">Bri Bri Way</p><p class="t-role">Sound Healing & Breathwork</p></div>
            <div class="t-card"><p class="t-quote">"The breathwork sessions were unlike anything I'd experienced. I feel more connected to my body than I ever have."</p><p class="t-name">Jamie L.</p><p class="t-role">Breathwork Class</p></div>
            <div class="t-card"><p class="t-quote">"I came in for the 1:1 package not knowing what to expect. What happened over those three months genuinely shifted something deep in me."</p><p class="t-name">Priya S.</p><p class="t-role">1:1 Transformation Client</p></div>
            <div class="t-card"><p class="t-quote">"Anna's presence alone creates safety. I've done a lot of personal work and this was the most integrated approach I've encountered."</p><p class="t-name">Lily W.</p><p class="t-role">1:1 Transformation Client</p></div>
            <!-- Duplicate for seamless loop -->
            <div class="t-card"><p class="t-quote">"Anna's sound healing and breathwork session was an absolute delight. She created a safe and nurturing space for each individual, allowing them to explore their inner selves. Before the sound bath, Anna guided us into a beautiful meditation, and she even incorporated breathwork into the session. While the breathwork was intense at times, it was an incredibly liberating experience. Overall, I highly recommend Anna's sessions to anyone seeking a spiritual journey."</p><p class="t-name">Bri Bri Way</p><p class="t-role">Sound Healing & Breathwork</p></div>
            <div class="t-card"><p class="t-quote">"The breathwork sessions were unlike anything I'd experienced. I feel more connected to my body than I ever have."</p><p class="t-name">Jamie L.</p><p class="t-role">Breathwork Class</p></div>
            <div class="t-card"><p class="t-quote">"I came in for the 1:1 package not knowing what to expect. What happened over those three months genuinely shifted something deep in me."</p><p class="t-name">Priya S.</p><p class="t-role">1:1 Transformation Client</p></div>
            <div class="t-card"><p class="t-quote">"Anna's presence alone creates safety. I've done a lot of personal work and this was the most integrated approach I've encountered."</p><p class="t-name">Lily W.</p><p class="t-role">1:1 Transformation Client</p></div>
          </div>
        </div>

        <!-- Column 2 -->
        <div class="t-col">
          <div class="t-scroll t-scroll-2">
            <div class="t-card"><p class="t-quote">"I was skeptical about hypnosis but Anna made it feel so safe and grounded. I've released patterns I've carried for decades."</p><p class="t-name">Rachel T.</p><p class="t-role">1:1 Transformation Client</p></div>
            <div class="t-card"><p class="t-quote">"The Women's Group became the most consistent source of growth in my week. I can't imagine not having it now."</p><p class="t-name">Danielle R.</p><p class="t-role">Women's Group Member</p></div>
            <div class="t-card"><p class="t-quote">"Anna holds space in a way that's rare. I left every session feeling seen, supported, and clearer than when I arrived."</p><p class="t-name">Morgan K.</p><p class="t-role">1:1 Transformation Client</p></div>
            <div class="t-card"><p class="t-quote">"The sound bath was so restorative I didn't realize how much tension I was holding until it was gone. Absolutely beautiful."</p><p class="t-name">Elena V.</p><p class="t-role">In-Person Event</p></div>
            <!-- Duplicate for seamless loop -->
            <div class="t-card"><p class="t-quote">"I was skeptical about hypnosis but Anna made it feel so safe and grounded. I've released patterns I've carried for decades."</p><p class="t-name">Rachel T.</p><p class="t-role">1:1 Transformation Client</p></div>
            <div class="t-card"><p class="t-quote">"The Women's Group became the most consistent source of growth in my week. I can't imagine not having it now."</p><p class="t-name">Danielle R.</p><p class="t-role">Women's Group Member</p></div>
            <div class="t-card"><p class="t-quote">"Anna holds space in a way that's rare. I left every session feeling seen, supported, and clearer than when I arrived."</p><p class="t-name">Morgan K.</p><p class="t-role">1:1 Transformation Client</p></div>
            <div class="t-card"><p class="t-quote">"The sound bath was so restorative I didn't realize how much tension I was holding until it was gone. Absolutely beautiful."</p><p class="t-name">Elena V.</p><p class="t-role">In-Person Event</p></div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Classes Preview -->
  <section class="preview-section">
    <div class="container">
      <p class="section-tag center">Live Online</p>
      <h2 class="section-title center">Group Classes</h2>
      <div class="divider center"><span></span><span class="diamond">&#10022;</span><span></span></div>
      <div class="two-col">
        <div class="preview-card">
          <p class="card-tag">Every Tuesday &bull; 6:00–7:15 PM CST</p>
          <h3>Transformative Breathwork</h3>
          <p>Biodynamic breathwork and trauma release to regulate the nervous system and explore subconscious emotional patterns through conscious breathing.</p>
          <p class="price-line">Drop-in <strong>$40</strong> &nbsp;&bull;&nbsp; Monthly <strong>$129</strong></p>
          <a href="/classes" class="btn btn-outline">View Class Details</a>
        </div>
        <div class="preview-card">
          <p class="card-tag">Every Tuesday &bull; 7:30–9:00 PM CST</p>
          <h3>Women's Group</h3>
          <p>A facilitated weekly space combining guided meditation, sensuality, empowerment, and reflective practices for deeper emotional awareness and connection.</p>
          <p class="price-line">Monthly <strong>$149</strong></p>
          <a href="/classes" class="btn btn-outline">View Class Details</a>
        </div>
      </div>
      <p class="combo-note">&#10022; &nbsp; Attend both for <strong>$229/month</strong> — save $49</p>
    </div>
  </section>

  <!-- Digital Products Preview -->
  <section class="preview-section alt">
    <div class="container">
      <p class="section-tag center">Self-Guided Programs</p>
      <h2 class="section-title center">Digital Products</h2>
      <div class="divider center"><span></span><span class="diamond">&#10022;</span><span></span></div>
      <p class="section-intro">
        Hypnosis, sound healing, and reflective exercises designed to help you work with the
        subconscious mind at your own pace — repeatable, deeply supportive, and designed for lasting change.
      </p>
      <div class="three-col">
        <div class="product-card">
          <h3>Body Transformation Program</h3>
          <p>Subconscious patterns that influence habits, identity, and relationship with the body.</p>
          <p class="price">$197</p>
          <a href="/products" class="btn btn-outline">Learn More</a>
        </div>
        <div class="product-card featured-card">
          <h3>Fertility Hypnosis Program</h3>
          <p>Create a calm internal environment to support your fertility journey through relaxation and trust in the body.</p>
          <p class="price">$297</p>
          <a href="/products" class="btn btn-gold">Learn More</a>
        </div>
        <div class="product-card">
          <h3>Connect to Your Higher Self</h3>
          <p>Deeper self-awareness and connection with inner guidance through hypnosis and meditation.</p>
          <p class="price">$197</p>
          <a href="/products" class="btn btn-outline">Learn More</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Events Teaser -->
  <section class="preview-section">
    <div class="container events-teaser">
      <p class="section-tag center">Northwest Arkansas</p>
      <h2 class="section-title center">In-Person Events</h2>
      <div class="divider center"><span></span><span class="diamond">&#10022;</span><span></span></div>
      <p class="section-intro">
        Live experiences designed to support relaxation, nervous system regulation, and deeper
        self-awareness. Anna has facilitated over 100 community events — from sound baths and
        breathwork to women's retreats and corporate wellness experiences.
      </p>
      <div class="events-tags">
        <span>Sound Bath</span><span>Breathwork</span><span>Women's Circles</span>
        <span>Cacao Ceremonies</span><span>Guided Meditation</span><span>Private &amp; Corporate</span>
      </div>
      <a href="/events" class="btn btn-outline">View Events &amp; Inquire</a>
    </div>
  </section>

  <!-- Modalities Strip -->
  <section class="modalities">
    <div class="container">
      <p class="section-tag center">The Work</p>
      <div class="modality-grid">
        <div class="modality">&#9670; Hypnosis</div>
        <div class="modality">&#9670; Breathwork</div>
        <div class="modality">&#9670; Sound Healing</div>
        <div class="modality">&#9670; Reiki</div>
        <div class="modality">&#9670; Meditation</div>
        <div class="modality">&#9670; Spiritual Guidance</div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="final-cta">
    <div class="container">
      <p class="section-tag center">Begin Your Journey</p>
      <h2 class="section-title center">Ready to explore?</h2>
      <div class="divider center"><span></span><span class="diamond">&#10022;</span><span></span></div>
      <p class="final-cta-text">
        Schedule a free consultation to explore whether this work is right for you.
        No commitment required — just a conversation.
      </p>
      <a href="#" onclick={`Calendly.initPopupWidget({url: '${CALENDLY}'});return false;`} class="btn btn-gold">Book a Free Consultation</a>
    </div>
  </section>

  <footer class="footer">
    <p>&copy; {new Date().getFullYear()} Anna Wooten. All rights reserved.</p>
  </footer>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 8rem 3rem 5rem;
  }
  .hero-inner { max-width: 760px; }
  .hero h1 { font-size: clamp(3rem, 6.5vw, 5rem); color: var(--text); margin-bottom: 1.5rem; }
  .hero h1 em { color: var(--gold); font-style: italic; }
  .hero-desc { font-size: 1.05rem; color: var(--muted); max-width: 520px; margin: 0 auto 2.5rem; line-height: 1.9; }
  .hero-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  /* About teaser */
  .about-teaser { padding: 8rem 0; }
  .about-teaser-grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 5rem; align-items: center; }
  .about-teaser-img { position: relative; }
  .about-teaser-img::before {
    content: '';
    position: absolute; inset: -6px;
    border-radius: 50% 50% 45% 45% / 48% 48% 40% 40%;
    background: linear-gradient(160deg, rgba(232,150,10,0.3), rgba(160,80,240,0.22));
    z-index: 0;
  }
  .about-teaser-img img {
    position: relative; z-index: 1;
    width: 100%; aspect-ratio: 3/4;
    object-fit: cover; object-position: top;
    border-radius: 50% 50% 45% 45% / 48% 48% 40% 40%;
    box-shadow: 0 0 60px rgba(160,80,240,0.3), 0 0 25px rgba(232,150,10,0.12);
  }
  .about-teaser-text h2 { font-size: 2.8rem; margin-bottom: 0.25rem; }
  .about-teaser-text p { color: var(--muted); margin-bottom: 1rem; line-height: 1.85; }

  /* Feature section (1:1) */
  .feature-section { padding: 8rem 0; }
  .feature-inner { text-align: center; max-width: 820px; margin: 0 auto; }
  .feature-desc { color: var(--muted); font-size: 1.05rem; line-height: 1.9; margin-bottom: 3rem; }
  .feature-pillars { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; margin-bottom: 2.5rem; text-align: left; }
  .pillar { padding: 1.8rem; border: 1px solid var(--card-border); border-radius: 12px; background: var(--card); }
  .pillar-icon { font-size: 1.2rem; color: var(--gold); display: block; margin-bottom: 0.8rem; }
  .pillar h4 { font-family: var(--font-display); font-size: 1.2rem; color: var(--text); margin-bottom: 0.6rem; }
  .pillar p { font-size: 0.88rem; color: var(--muted); line-height: 1.7; }
  .feature-detail { font-size: 0.8rem; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 2rem; text-transform: uppercase; }

  /* Preview sections */
  .preview-section { padding: 8rem 0; }
  .preview-section.alt { background: rgba(255,255,255,0.015); }
  .section-intro { color: var(--muted); font-size: 1rem; line-height: 1.85; max-width: 620px; margin: 0 auto 3rem; text-align: center; }

  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
  .preview-card {
    padding: 2.5rem;
    border: 1px solid var(--card-border);
    border-radius: 14px;
    background: var(--card);
    backdrop-filter: blur(6px);
    transition: border-color 0.3s, transform 0.3s;
  }
  .preview-card:hover { border-color: var(--border); transform: translateY(-3px); }
  .card-tag { font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.9rem; }
  .preview-card h3 { font-family: var(--font-display); font-size: 1.7rem; color: var(--text); margin-bottom: 0.9rem; }
  .preview-card p { font-size: 0.9rem; color: var(--muted); line-height: 1.75; margin-bottom: 1rem; }
  .price-line { color: var(--text) !important; font-size: 0.88rem !important; }
  .price-line strong { color: var(--gold); }
  .combo-note { text-align: center; margin-top: 1.5rem; color: var(--muted); font-size: 0.88rem; }
  .combo-note strong { color: var(--text); }

  .three-col { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .product-card {
    padding: 2.2rem;
    border: 1px solid var(--card-border);
    border-radius: 14px;
    background: var(--card);
    text-align: center;
    transition: border-color 0.3s, transform 0.3s;
  }
  .product-card:hover { border-color: var(--border); transform: translateY(-3px); }
  .product-card.featured-card { border-color: rgba(232,150,10,0.35); background: rgba(232,150,10,0.06); }
  .product-card h3 { font-family: var(--font-display); font-size: 1.5rem; color: var(--text); margin-bottom: 0.8rem; }
  .product-card p { font-size: 0.88rem; color: var(--muted); line-height: 1.7; margin-bottom: 1.2rem; }
  .price { font-family: var(--font-display); font-size: 2rem; color: var(--gold); margin-bottom: 1.5rem; }

  /* Events */
  .events-teaser { text-align: center; }
  .events-tags { display: flex; flex-wrap: wrap; gap: 0.7rem; justify-content: center; margin: 0 auto 2.5rem; max-width: 600px; }
  .events-tags span {
    padding: 0.4rem 1rem;
    border: 1px solid rgba(232,150,10,0.25);
    border-radius: 9999px;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    color: var(--muted);
  }

  /* Modalities */
  .modalities { padding: 5rem 0; border-top: 1px solid rgba(232,150,10,0.08); border-bottom: 1px solid rgba(232,150,10,0.08); }
  .modality-grid { display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem 3rem; margin-top: 1.5rem; }
  .modality { font-size: 0.82rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); }

  /* Final CTA */
  .final-cta { padding: 9rem 0; text-align: center; }
  .final-cta-text { color: var(--muted); max-width: 480px; margin: 0 auto 2.5rem; line-height: 1.85; }


  /* Testimonials */
  .testimonials {
    padding: 8rem 0;
  }
  .testimonials-header {
    margin-bottom: 3rem;
  }
  .testimonials-track-wrap {
    position: relative;
    height: 580px;
    overflow: hidden;
    mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 18%,
      black 82%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 18%,
      black 82%,
      transparent 100%
    );
  }
  .testimonials-cols {
    display: flex;
    gap: 1.5rem;
    max-width: 860px;
    margin: 0 auto;
    padding: 0 3rem;
    height: 100%;
  }
  .t-col {
    flex: 1;
    overflow: hidden;
  }
  .t-scroll {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .t-scroll-1 {
    animation: scroll-up 28s linear infinite;
  }
  .t-scroll-2 {
    animation: scroll-up 22s linear infinite;
    margin-top: -120px;
  }
  @keyframes scroll-up {
    0%   { transform: translateY(0); }
    100% { transform: translateY(-50%); }
  }
  .t-card {
    padding: 1.8rem 2rem;
    border: 1px solid var(--card-border);
    border-radius: 14px;
    background: var(--card);
    backdrop-filter: blur(8px);
    flex-shrink: 0;
  }
  .t-quote {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-style: italic;
    color: var(--text);
    line-height: 1.7;
    margin-bottom: 1.2rem;
  }
  .t-name {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--gold);
    letter-spacing: 0.06em;
  }
  .t-role {
    font-size: 0.75rem;
    color: var(--muted);
    letter-spacing: 0.05em;
    margin-top: 0.2rem;
  }
  @media (max-width: 768px) {
    .testimonials-cols { gap: 1rem; padding: 0 1rem; }
    .t-scroll-2 { display: none; }
    .testimonials-cols { max-width: 100%; }
  }

  @media (max-width: 900px) {
    .feature-pillars { grid-template-columns: 1fr; }
    .three-col { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .hero { padding: 7rem 1.5rem 4rem; }
    .about-teaser { padding: 5rem 0; }
    .about-teaser-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .two-col { grid-template-columns: 1fr; }
    .preview-section { padding: 5rem 0; }
    .feature-section { padding: 5rem 0; }
    .final-cta { padding: 6rem 0; }
  }
</style>

