<style>
  /* Hero */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 8rem 3rem 5rem;
  }
  .hero-inner { max-width: 760px; }
  .hero h1 { font-size: clamp(3rem, 6.5vw, 5rem); color: var(--text); margin-bottom: 1.5rem; }
  .hero h1 em { color: var(--gold); font-style: italic; }
  .hero-desc { font-size: 1.05rem; color: var(--muted); max-width: 520px; margin: 0 auto 2.5rem; line-height: 1.9; }
  .hero-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  /* About teaser */
  .about-teaser { padding: 8rem 0; }
  .about-teaser-grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 5rem; align-items: center; }
  .about-teaser-img { position: relative; }
  .about-teaser-img::before {
    content: '';
    position: absolute; inset: -6px;
    border-radius: 50% 50% 45% 45% / 48% 48% 40% 40%;
    background: linear-gradient(160deg, rgba(232,150,10,0.3), rgba(160,80,240,0.22));
    z-index: 0;
  }
  .about-teaser-img img {
    position: relative; z-index: 1;
    width: 100%; aspect-ratio: 3/4;
    object-fit: cover; object-position: top;
    border-radius: 50% 50% 45% 45% / 48% 48% 40% 40%;
    box-shadow: 0 0 60px rgba(160,80,240,0.3), 0 0 25px rgba(232,150,10,0.12);
  }
  .about-teaser-text h2 { font-size: 2.8rem; margin-bottom: 0.25rem; }
  .about-teaser-text p { color: var(--muted); margin-bottom: 1rem; line-height: 1.85; }

  /* Feature section (1:1) */
  .feature-section { padding: 8rem 0; }
  .feature-inner { text-align: center; max-width: 820px; margin: 0 auto; }
  .feature-desc { color: var(--muted); font-size: 1.05rem; line-height: 1.9; margin-bottom: 3rem; }
  .feature-pillars { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; margin-bottom: 2.5rem; text-align: left; }
  .pillar { padding: 1.8rem; border: 1px solid var(--card-border); border-radius: 12px; background: var(--card); }
  .pillar-icon { font-size: 1.2rem; color: var(--gold); display: block; margin-bottom: 0.8rem; }
  .pillar h4 { font-family: var(--font-display); font-size: 1.2rem; color: var(--text); margin-bottom: 0.6rem; }
  .pillar p { font-size: 0.88rem; color: var(--muted); line-height: 1.7; }
  .feature-detail { font-size: 0.8rem; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 2rem; text-transform: uppercase; }

  /* Preview sections */
  .preview-section { padding: 8rem 0; }
  .preview-section.alt { background: rgba(255,255,255,0.015); }
  .section-intro { color: var(--muted); font-size: 1rem; line-height: 1.85; max-width: 620px; margin: 0 auto 3rem; text-align: center; }

  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
  .preview-card {
    padding: 2.5rem;
    border: 1px solid var(--card-border);
    border-radius: 14px;
    background: var(--card);
    backdrop-filter: blur(6px);
    transition: border-color 0.3s, transform 0.3s;
  }
