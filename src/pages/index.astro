              <line x1="44" y1="45" x2="44" y2="41" stroke="#e8960a" stroke-width="0.8" opacity="0.45"/>
              <line x1="53" y1="49" x2="56" y2="46" stroke="#e8960a" stroke-width="0.8" opacity="0.45"/>
              <line x1="53" y1="63" x2="56" y2="66" stroke="#e8960a" stroke-width="0.8" opacity="0.45"/>
              <line x1="44" y1="67" x2="44" y2="71" stroke="#e8960a" stroke-width="0.8" opacity="0.45"/>
              <line x1="35" y1="63" x2="32" y2="66" stroke="#e8960a" stroke-width="0.8" opacity="0.45"/>
              <line x1="35" y1="49" x2="32" y2="46" stroke="#e8960a" stroke-width="0.8" opacity="0.45"/>
            </svg>
          </div>
          <h3>Fertility Hypnosis Program</h3>
          <p>Create a calm internal environment to support your fertility journey through relaxation and trust in the body.</p>
          <p class="price">$297</p>
          <a href="/products" class="btn btn-gold">Learn More</a>
        </div>
        <div class="product-card">
          <div class="product-icon">
            <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
              <line x1="50" y1="20" x2="50" y2="14" stroke="#e8960a" stroke-width="1" opacity="0.7"/>
              <line x1="43" y1="22" x2="40" y2="16" stroke="#e8960a" stroke-width="0.9" opacity="0.6"/>
              <line x1="57" y1="22" x2="60" y2="16" stroke="#e8960a" stroke-width="0.9" opacity="0.6"/>
              <line x1="37" y1="26" x2="33" y2="22" stroke="#e8960a" stroke-width="0.8" opacity="0.5"/>
