          <div class="modality-visual mod-breathwork"></div>
          <h4>Breathwork</h4>
        </div>
        <div class="modality-card">
          <div class="modality-visual mod-sound"></div>
          <h4>Sound Healing</h4>
        </div>
        <div class="modality-card">
          <div class="modality-visual mod-reiki"></div>
          <h4>Reiki</h4>
        </div>
