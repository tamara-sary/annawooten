---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Anna Wooten — Sessions & Wellness">
  <!-- Navigation -->
  <nav class="nav">
    <a href="/" class="nav-logo">Anna Wooten</a>
    <div class="nav-links">
      <a href="#about">About</a>
      <a href="#sessions">Sessions</a>
      <a href="#contact">Contact</a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-content">
      <p class="hero-tag">Welcome</p>
      <h1>Your journey to<br /><em>wellness</em> starts here</h1>
      <p class="hero-description">
        Personalized sessions designed to help you reconnect with yourself and find balance in your everyday life.
      </p>
      <a href="#sessions" class="btn">Explore Sessions</a>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="about">
    <div class="container">
      <div class="about-grid">
        <div class="about-image">
          <img src="/anna.jpg" alt="Anna Wooten" />
        </div>
        <div class="about-text">
          <p class="section-tag">About</p>
          <h2>Hi, I'm Anna</h2>
          <p>
            This is a placeholder for Anna's bio. She can edit this text directly from the CMS admin panel — no coding needed.
          </p>
          <p>
            Add your story, your approach, what makes your sessions unique, and why clients love working with you.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sessions -->
  <section id="sessions" class="sessions">
    <div class="container">
      <p class="section-tag center">What I Offer</p>
      <h2 class="section-title">Sessions</h2>
      <div class="sessions-grid">
        <div class="session-card">
          <span class="session-duration">60 min</span>
          <h3>Individual Session</h3>
          <p>One-on-one personalized session tailored to your needs and goals.</p>
          <div class="session-price">€80</div>
          <a href="#contact" class="btn btn-outline">Book Now</a>
        </div>
        <div class="session-card featured">
          <span class="session-duration">90 min</span>
          <h3>Deep Dive Session</h3>
          <p>An extended session for deeper exploration and transformation.</p>
          <div class="session-price">€120</div>
          <a href="#contact" class="btn">Book Now</a>
        </div>
        <div class="session-card">
          <span class="session-duration">4 weeks</span>
          <h3>Package Program</h3>
          <p>A structured program with weekly sessions for lasting change.</p>
          <div class="session-price">€280</div>
          <a href="#contact" class="btn btn-outline">Book Now</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="contact">
    <div class="container">
      <p class="section-tag center">Get in Touch</p>
      <h2 class="section-title">Ready to start?</h2>
      <p class="contact-text">
        Reach out to book a session or ask any questions. I'd love to hear from you.
      </p>
      <a href="mailto:hello@annawooten.com" class="btn">Send me an email</a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <p>&copy; {new Date().getFullYear()} Anna Wooten. All rights reserved.</p>
  </footer>
</BaseLayout>

<style>
  /* Navigation */
  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 3rem;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(10, 6, 20, 0.75);
    backdrop-filter: blur(10px);
  }

  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: 0.02em;
    color: var(--color-cream);
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-cream);
  }

  .nav-links a {
    color: var(--color-cream);
    opacity: 0.85;
  }

  .nav-links a:hover {
    color: var(--color-accent);
    opacity: 1;
    transition: color 0.3s;
  }

  /* Hero */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 6rem 3rem 3rem;
    position: relative;
  }

  .hero-content {
    max-width: 700px;
    position: relative;
    z-index: 1;
  }

  .hero-tag {
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
  }

  .hero h1 {
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    margin-bottom: 1.5rem;
    color: var(--color-cream);
  }

  .hero h1 em {
    color: var(--color-accent);
    font-style: italic;
  }

  .hero-description {
    font-size: 1.1rem;
    color: rgba(251, 248, 244, 0.75);
    max-width: 480px;
    margin-bottom: 2.5rem;
    line-height: 1.8;
  }

  /* Buttons */
  .btn {
    display: inline-block;
    padding: 0.9rem 2.2rem;
    background: var(--color-warm-black);
    color: var(--color-cream);
    font-family: var(--font-body);
    font-size: 0.82rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 1px solid var(--color-warm-black);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .btn:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  .btn-outline {
    background: transparent;
    color: var(--color-warm-black);
  }

  .btn-outline:hover {
    background: var(--color-warm-black);
    color: var(--color-cream);
  }

  /* Sections */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 3rem;
  }

  .section-tag {
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .section-tag.center {
    text-align: center;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    text-align: center;
    margin-bottom: 3rem;
  }

  /* About */
  .about {
    padding: 8rem 0;
    background: var(--color-cream);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .about-image img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  .about-text h2 {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
  }

  .about-text p {
    color: var(--color-muted);
    margin-bottom: 1rem;
    line-height: 1.8;
  }

  /* Sessions */
  .sessions {
    padding: 8rem 0;
    background: white;
  }

  .sessions-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .session-card {
    padding: 2.5rem;
    border: 1px solid var(--color-accent-light);
    text-align: center;
    transition: all 0.3s ease;
  }

  .session-card:hover {
    border-color: var(--color-accent);
  }

  .session-card.featured {
    background: var(--color-warm-black);
    color: var(--color-cream);
    border-color: var(--color-warm-black);
  }

  .session-card.featured .session-duration {
    color: var(--color-accent);
  }

  .session-card.featured .session-price {
    color: var(--color-cream);
  }

  .session-card.featured .btn {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  .session-duration {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .session-card h3 {
    font-family: var(--font-display);
    font-size: 1.6rem;
    margin: 1rem 0;
  }

  .session-card p {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .session-card.featured p {
    color: var(--color-accent-light);
  }

  .session-price {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--color-warm-black);
    margin-bottom: 1.5rem;
  }

  /* Contact */
  .contact {
    padding: 8rem 0;
    text-align: center;
  }

  .contact-text {
    color: var(--color-muted);
    max-width: 500px;
    margin: 0 auto 2.5rem;
    line-height: 1.8;
  }

  /* Footer */
  .footer {
    padding: 3rem;
    text-align: center;
    font-size: 0.8rem;
    color: var(--color-muted);
    letter-spacing: 0.05em;
    border-top: 1px solid var(--color-accent-light);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .nav {
      padding: 1.2rem 1.5rem;
    }
    .nav-links {
      gap: 1.5rem;
      font-size: 0.75rem;
    }
    .hero {
      padding: 6rem 1.5rem 3rem;
    }
    .container {
      padding: 0 1.5rem;
    }
    .about-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .sessions-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
