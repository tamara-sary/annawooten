---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Anna Wooten — Sessions & Wellness">

  <!-- Navigation -->
  <nav class="nav">
    <a href="/" class="nav-logo">Anna Wooten</a>
    <div class="nav-links">
      <a href="#about">About</a>
      <a href="#sessions">Sessions</a>
      <a href="#contact">Contact</a>
    </div>
    <a href="#contact" class="nav-cta">Book a Session</a>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-content">
      <span class="hero-icon">&#9790;</span>
      <p class="hero-tag">Wellness &amp; Personal Sessions</p>
      <h1>Your journey to<br /><em>wellness</em> starts here</h1>
      <p class="hero-description">
        Personalized sessions designed to help you reconnect with yourself
        and find balance in your everyday life.
      </p>
      <div class="hero-buttons">
        <a href="#sessions" class="btn btn-gold">Explore Sessions</a>
        <a href="#about" class="btn btn-outline">Meet Anna</a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="about">
    <div class="container">
      <div class="about-grid">
        <div class="about-image-wrap">
          <img src="/anna.jpg" alt="Anna Wooten" class="about-photo" />
        </div>
        <div class="about-text">
          <p class="section-tag">About the Guide</p>
          <h2>Hi, I'm Anna</h2>
          <div class="divider"><span></span><span class="diamond">&#10022;</span><span></span></div>
          <p>
            This is a placeholder for Anna's bio. She can edit this text directly
            from the CMS admin panel — no coding needed.
          </p>
          <p>
            Add your story, your approach, what makes your sessions unique,
            and why clients love working with you.
          </p>
          <a href="#contact" class="btn btn-gold" style="margin-top: 2rem;">Work With Me</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Sessions -->
  <section id="sessions" class="sessions">
    <div class="container">
      <p class="section-tag center">What I Offer</p>
      <h2 class="section-title">Sessions</h2>
      <div class="sessions-grid">
        <div class="session-card">
          <span class="session-duration">60 min</span>
          <h3>Individual Session</h3>
          <p>One-on-one personalized session tailored to your needs and goals.</p>
          <div class="session-price">&#8364;80</div>
          <a href="#contact" class="btn btn-outline">Book Now</a>
        </div>
        <div class="session-card featured">
          <span class="session-duration">90 min</span>
          <h3>Deep Dive Session</h3>
          <p>An extended session for deeper exploration and transformation.</p>
          <div class="session-price">&#8364;120</div>
          <a href="#contact" class="btn btn-gold">Book Now</a>
        </div>
        <div class="session-card">
          <span class="session-duration">4 weeks</span>
          <h3>Package Program</h3>
          <p>A structured program with weekly sessions for lasting change.</p>
          <div class="session-price">&#8364;280</div>
          <a href="#contact" class="btn btn-outline">Book Now</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="contact">
    <div class="container">
      <p class="section-tag center">Get in Touch</p>
      <h2 class="section-title">Ready to start?</h2>
      <div class="divider center-divider"><span></span><span class="diamond">&#10022;</span><span></span></div>
      <p class="contact-text">
        Reach out to book a session or ask any questions. I'd love to hear from you.
      </p>
      <a href="mailto:hello@annawooten.com" class="btn btn-gold">Send me an email</a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <p>&copy; {new Date().getFullYear()} Anna Wooten. All rights reserved.</p>
  </footer>

</BaseLayout>

<style>
  /* ── Nav ────────────────────────────────────────────── */
  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.4rem 3rem;
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(13, 10, 30, 0.78);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(201, 168, 76, 0.1);
  }

  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.4rem;
    letter-spacing: 0.03em;
    color: var(--text);
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(240, 234, 222, 0.75);
  }

  .nav-links a:hover { color: var(--gold); transition: color 0.3s; }

  .nav-cta {
    padding: 0.55rem 1.4rem;
    background: var(--gold);
    color: var(--bg);
    border-radius: 9999px;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: opacity 0.3s;
  }
  .nav-cta:hover { opacity: 0.85; }

  /* ── Hero ───────────────────────────────────────────── */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 7rem 3rem 4rem;
  }

  .hero-content { max-width: 720px; }

  .hero-icon {
    display: block;
    font-size: 2rem;
    color: var(--gold);
    margin-bottom: 1.5rem;
    opacity: 0.85;
  }

  .hero-tag {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.5rem;
  }

  .hero h1 {
    font-size: clamp(3rem, 7vw, 5.5rem);
    color: var(--text);
    margin-bottom: 1.5rem;
    line-height: 1.15;
  }

  .hero h1 em {
    color: var(--gold);
    font-style: italic;
  }

  .hero-description {
    font-size: 1.05rem;
    color: var(--muted);
    max-width: 500px;
    margin: 0 auto 2.5rem;
    line-height: 1.85;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── Buttons ────────────────────────────────────────── */
  .btn {
    display: inline-block;
    padding: 0.85rem 2.2rem;
    border-radius: 9999px;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .btn-gold {
    background: var(--gold);
    color: var(--bg);
    border: 1px solid var(--gold);
  }
  .btn-gold:hover { opacity: 0.85; }

  .btn-outline {
    background: transparent;
    color: var(--text);
    border: 1px solid rgba(240, 234, 222, 0.35);
  }
  .btn-outline:hover {
    border-color: var(--gold);
    color: var(--gold);
  }

  /* ── Shared ─────────────────────────────────────────── */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 3rem;
  }

  .section-tag {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
  }
  .section-tag.center { text-align: center; }

  .section-title {
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    text-align: center;
    color: var(--text);
    margin-bottom: 3rem;
  }

  .divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 1.2rem 0 1.8rem;
  }
  .divider span:first-child,
  .divider span:last-child {
    flex: 1;
    height: 1px;
    background: var(--gold);
    opacity: 0.4;
    max-width: 60px;
  }
  .diamond { color: var(--gold); font-size: 0.9rem; }

  .center-divider {
    justify-content: center;
    margin-bottom: 2rem;
  }
  .center-divider span:first-child,
  .center-divider span:last-child { max-width: 80px; }

  /* ── About ──────────────────────────────────────────── */
  .about { padding: 9rem 0; }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 5rem;
    align-items: center;
  }

  .about-image-wrap {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .about-image-wrap::before {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: 50% 50% 45% 45% / 48% 48% 40% 40%;
    background: linear-gradient(160deg, rgba(201,168,76,0.35), rgba(160,80,240,0.25));
    z-index: 0;
  }

  .about-photo {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 400px;
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: top;
    border-radius: 50% 50% 45% 45% / 48% 48% 40% 40%;
    box-shadow: 0 0 60px rgba(160, 80, 240, 0.3), 0 0 30px rgba(201, 168, 76, 0.15);
  }

  .about-text h2 {
    font-size: clamp(2.2rem, 4vw, 3rem);
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .about-text p {
    color: var(--muted);
    margin-bottom: 1rem;
    line-height: 1.85;
  }

  /* ── Sessions ───────────────────────────────────────── */
  .sessions { padding: 9rem 0; }

  .sessions-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .session-card {
    padding: 2.5rem 2rem;
    border-radius: 16px;
    border: 1px solid var(--card-border);
    background: var(--card);
    text-align: center;
    backdrop-filter: blur(8px);
    transition: border-color 0.3s, transform 0.3s;
  }
  .session-card:hover {
    border-color: var(--border);
    transform: translateY(-4px);
  }

  .session-card.featured {
    border-color: rgba(201, 168, 76, 0.4);
    background: rgba(201, 168, 76, 0.07);
    box-shadow: 0 0 40px rgba(201, 168, 76, 0.1);
  }

  .session-duration {
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .session-card h3 {
    font-size: 1.6rem;
    color: var(--text);
    margin: 0.8rem 0;
  }

  .session-card p {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 1.5rem;
  }

  .session-price {
    font-family: var(--font-display);
    font-size: 2.2rem;
    color: var(--gold);
    margin-bottom: 1.5rem;
  }

  /* ── Contact ────────────────────────────────────────── */
  .contact {
    padding: 9rem 0;
    text-align: center;
  }

  .contact-text {
    color: var(--muted);
    max-width: 460px;
    margin: 0 auto 2.5rem;
    line-height: 1.85;
  }

  /* ── Footer ─────────────────────────────────────────── */
  .footer {
    padding: 2.5rem;
    text-align: center;
    font-size: 0.78rem;
    color: rgba(240, 234, 222, 0.35);
    letter-spacing: 0.06em;
    border-top: 1px solid rgba(201, 168, 76, 0.12);
  }

  /* ── Responsive ─────────────────────────────────────── */
  @media (max-width: 768px) {
    .nav { padding: 1.1rem 1.5rem; }
    .nav-links { display: none; }
    .hero { padding: 6rem 1.5rem 3rem; }
    .container { padding: 0 1.5rem; }
    .about-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .about-image-wrap { max-width: 300px; margin: 0 auto; }
    .sessions-grid { grid-template-columns: 1fr; }
  }
</style>
