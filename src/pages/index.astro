              <path d="M50 46 Q58 54 66 60" stroke="#e8960a" stroke-width="1.1" stroke-linecap="round"/>
              <path d="M50 52 Q40 58 28 64" stroke="#e8960a" stroke-width="1.2" stroke-linecap="round"/>
              <path d="M50 52 Q60 58 72 64" stroke="#e8960a" stroke-width="1.2" stroke-linecap="round"/>
              <path d="M28 64 Q36 68 44 64" stroke="#e8960a" stroke-width="1" stroke-linecap="round"/>
              <path d="M72 64 Q64 68 56 64" stroke="#e8960a" stroke-width="1" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>Connect to Your Higher Self</h3>
          <p>Deeper self-awareness and connection with inner guidance through hypnosis and meditation.</p>
          <p class="price">$197</p>
          <a href="/products" class="btn btn-outline">Learn More</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Events Teaser -->
  <section class="preview-section">
    <div class="container">
      <div class="events-teaser-grid">
        <div class="events-visual" style="background-image: url('/events-anna.jpeg'); background-position: 58% center;"></div>
        <div class="events-teaser-content">
          <p class="section-tag">Northwest Arkansas</p>
          <h2 class="section-title">In-Person Events</h2>
          <div class="divider"><span></span><span class="diamond">&#10022;</span><span></span></div>
          <p class="section-intro" style="text-align:left; margin:0 0 2rem;">
            Live experiences designed to support relaxation, nervous system regulation, and deeper
            self-awareness. Anna has facilitated over 100 community events — from sound baths and
            breathwork to women's retreats and corporate wellness experiences.
          </p>
          <div class="events-tags">
            <span>Sound Bath</span><span>Breathwork</span><span>Women's Circles</span>
            <span>Cacao Ceremonies</span><span>Guided Meditation</span><span>Private &amp; Corporate</span>
          </div>
          <a href="/events" class="btn btn-outline" style="margin-top:2rem; display:inline-block;">View Events &amp; Inquire</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Modalities -->
  <section class="modalities">
    <div class="container">
      <p class="section-tag center">The Work</p>
      <h2 class="section-title center">Modalities</h2>
      <div class="divider center"><span></span><span class="diamond">&#10022;</span><span></span></div>
      <div class="modality-grid">
        <div class="modality-card">
          <div class="modality-visual mod-hypnosis" style="background-image: url('/mod-hypnosis.jpeg'); background-position: center 40%; background-size: 120%;"></div>
