---
import BaseLayout from '../layouts/BaseLayout.astro';
import pg from '../content/products.json';
const CALENDLY = 'https://calendly.com/annawootenofficial';
---
<BaseLayout title="Digital Products — Anna Wooten" description="Self-guided hypnosis programs combining subconscious work, sound healing, and reflective exercises.">
  <nav class="nav">
    <a href="/" class="nav-logo">Anna Wooten</a>
    <div class="nav-links">
      <a href="/about">About</a>
      <a href="/work-with-me">Work With Me</a>
      <a href="/classes">Classes</a>
      <a href="/products" style="color: var(--gold)">Products</a>
      <a href="/events">Events</a>
    </div>
    <a href="#" onclick={`Calendly.initPopupWidget({url: '${CALENDLY}'});return false;`} class="nav-cta">Book a Consultation</a>
  </nav>

  <div class="page-hero">
    <p class="section-tag">Self-Guided Programs</p>
    <h1>Digital Products</h1>
    <p>{pg.hero_description}</p>
  </div>

  <section class="products-intro">
    <div class="container">
      <div class="how-it-works">
        <p class="section-tag center">How It Works</p>
        <div class="steps">
          {pg.how_it_works.map((step: string, i: number) => (
            <div class="step">
              <span class="step-num">{String(i + 1).padStart(2, '0')}</span>
              <p>{step}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="products-section">
    <div class="container">
      {pg.products.map((prod: any, i: number) => (
        <>
          {i > 0 && <div class="product-divider"></div>}
          <div class="product-full">
            <div class="product-text">
              <p class="section-tag">{prod.num}</p>
              <h2>{prod.title}</h2>
              <div class="divider"><span></span><span class="diamond">&#10022;</span><span></span></div>
              <p>{prod.para1}</p>
              <p>{prod.para2}</p>
              <div class="includes-list">
                <p class="includes-title">Includes:</p>
                {prod.includes.map((item: string) => (
                  <div class="include-item">&#10022; {item}</div>
                ))}
              </div>
            </div>
            <div class={`product-cta-box${prod.featured ? ' featured-box' : ''}`}>
              <div class="cta-price">{prod.price}</div>
              <a href={prod.buy_url || '#'} target="_blank" class="btn btn-gold" style="width:100%;text-align:center;">Get Instant Access</a>
              <p class="cta-note">Delivered via email after purchase</p>
            </div>
          </div>
        </>
      ))}
    </div>
  </section>

  <!-- Newsletter Popup -->
  <div id="newsletter-popup" class="popup-overlay" role="dialog" aria-modal="true">
    <div class="popup-card">
      <button class="popup-close" id="popup-close-btn" aria-label="Close">&times;</button>
      <p class="section-tag center">Stay Connected</p>
      <h2 class="popup-title">Join the Circle</h2>
      <div class="divider center"><span></span><span class="diamond">&#10022;</span><span></span></div>
      <p class="popup-desc">Get updates on upcoming classes, events, and offerings from Anna.</p>
      <a href="https://docs.google.com/forms/d/e/1FAIpQLSeik7iE0JaHG8BqFo7seM37_HhCADFSTDFQJil-HuiV3vzBMQ/viewform" target="_blank" rel="noopener noreferrer" class="btn btn-gold popup-cta" onclick="closePopup()">Sign Me Up</a>
      <p class="popup-note">No spam, ever. Unsubscribe anytime.</p>
    </div>
  </div>

  <script is:inline>
    function closePopup() {
      var popup = document.getElementById('newsletter-popup');
      if (popup) popup.classList.remove('popup-visible');
    }
    document.getElementById('popup-close-btn').addEventListener('click', closePopup);
    document.getElementById('newsletter-popup').addEventListener('click', function(e) {
      if (e.target === this) closePopup();
    });
    var seen = localStorage.getItem('newsletterSeen');
    var now = Date.now();
    if (!seen || now - parseInt(seen) > 7 * 24 * 60 * 60 * 1000) {
      setTimeout(function() {
        document.getElementById('newsletter-popup').classList.add('popup-visible');
        localStorage.setItem('newsletterSeen', now.toString());
      }, 3000);
    }
  </script>

  <footer class="footer">
    <p>&copy; {new Date().getFullYear()} Anna Wooten. All rights reserved.</p>
  </footer>
</BaseLayout>

<style>
  .products-intro { padding: 4rem 0 2rem; }
  .how-it-works { max-width: 800px; margin: 0 auto; text-align: center; }
  .steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; margin-top: 2rem; }
  .step { text-align: center; }
  .step-num { display: block; font-family: var(--font-display); font-size: 2.5rem; color: var(--gold); opacity: 0.5; margin-bottom: 0.8rem; }
  .step p { font-size: 0.88rem; color: var(--muted); line-height: 1.7; }

  .products-section { padding: 5rem 0 8rem; }
  .product-full { display: grid; grid-template-columns: 1.5fr 1fr; gap: 5rem; align-items: start; padding: 4rem 0; }
  .product-divider { height: 1px; background: rgba(232,150,10,0.12); }
  .product-text h2 { font-size: clamp(1.8rem, 3vw, 2.6rem); margin-bottom: 0.25rem; }
  .product-text p { color: var(--muted); line-height: 1.85; margin-bottom: 1rem; }
  .includes-list { margin-top: 1.5rem; }
  .includes-title { font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.8rem; }
  .include-item { font-size: 0.9rem; color: var(--muted); padding: 0.4rem 0; line-height: 1.6; }

  .product-cta-box { padding: 2.5rem; border: 1px solid var(--card-border); border-radius: 16px; background: var(--card); text-align: center; position: sticky; top: calc(50vh - 120px); }
  .product-cta-box.featured-box { border-color: rgba(232,150,10,0.35); background: rgba(232,150,10,0.06); }
  .cta-price { font-family: var(--font-display); font-size: 3.5rem; color: var(--gold); margin-bottom: 1.5rem; }
  .cta-note { font-size: 0.75rem; color: var(--muted); margin-top: 1rem; letter-spacing: 0.05em; }

  @media (max-width: 900px) {
    .steps { grid-template-columns: 1fr 1fr; }
    .product-full { grid-template-columns: 1fr; }
    .product-cta-box { position: static; transform: none; }
  }
  @media (max-width: 768px) {
    .steps { grid-template-columns: 1fr; }
    .products-section { padding: 3rem 0 5rem; }
  }

  /* Newsletter popup */
  .popup-overlay { position: fixed; inset: 0; background: rgba(13,10,30,0.85); backdrop-filter: blur(10px); z-index: 999; display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.4s ease; padding: 1.5rem; }
  .popup-overlay.popup-visible { opacity: 1; pointer-events: all; }
  .popup-card { background: #16112e; border: 1px solid rgba(232,150,10,0.28); border-radius: 20px; padding: 3.5rem; max-width: 480px; width: 100%; text-align: center; position: relative; box-shadow: 0 0 60px rgba(160,80,240,0.2); }
  .popup-close { position: absolute; top: 1.2rem; right: 1.5rem; background: none; border: none; color: rgba(240,234,222,0.35); font-size: 1.8rem; cursor: pointer; line-height: 1; transition: color 0.2s; padding: 0; }
  .popup-close:hover { color: var(--gold); }
  .popup-title { font-size: 2.2rem; margin-bottom: 0.25rem; }
  .popup-desc { color: var(--muted); font-size: 0.95rem; line-height: 1.75; margin-bottom: 1.8rem; }
  .popup-form { display: flex; flex-direction: column; gap: 1rem; }
  .popup-cta { display: inline-block; margin-top: 0.5rem; }
  .popup-note { font-size: 0.72rem; color: var(--muted); margin-top: 1rem; opacity: 0.55; }
  @media (max-width: 600px) {
    .cta-price { font-size: clamp(2rem, 8vw, 3.5rem); }
    .products-section { padding: 2rem 0 4rem; }
  }
</style>
