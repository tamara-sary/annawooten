---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
const CALENDLY = 'https://calendly.com/annawootenofficial';

const entries = await getCollection('testimonials');
const sorted = entries.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
const rendered = await Promise.all(
  sorted.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  })
);
---

<BaseLayout title="Client Testimonials — Anna Wooten">

  <nav class="nav">
    <a href="/" class="nav-logo">Anna Wooten</a>
    <div class="nav-links">
      <a href="/about">About</a>
      <a href="/work-with-me">Work With Me</a>
      <a href="/classes">Classes</a>
      <a href="/products">Products</a>
      <a href="/events">Events</a>
    </div>
    <a href="#" onclick={`Calendly.initPopupWidget({url: '${CALENDLY}'});return false;`} class="nav-cta">Book a Consultation</a>
  </nav>

  <div class="page-hero">
    <p class="section-tag">Kind Words</p>
    <h1>What clients say</h1>
    <div class="divider center"><span></span><span class="diamond">&#10022;</span><span></span></div>
    <p>Real experiences from people who have done breathwork, sound healing, Reiki, hypnosis, and private sessions with Anna.</p>
  </div>

  <section class="testimonials-full">
    <div class="container">
      <div class="t-grid">
        {rendered.map(({ entry, Content }) => (
          <div class={`tf-card${entry.data.full_width ? ' tf-card--full' : ''}`}>
            <div class="tf-quote-mark">&#8220;</div>
            <Content />
            <div class="tf-author">
              <span class="tf-name">{entry.data.name}</span>
              <span class="tf-role">{entry.data.role}</span>
            </div>
          </div>
        ))}
      </div>

      <div class="back-link">
        <a href="/" class="btn btn-outline">&larr; Back to Home</a>
      </div>
    </div>
  </section>

  <footer class="footer">
    <p>&copy; {new Date().getFullYear()} Anna Wooten. All rights reserved.</p>
  </footer>

</BaseLayout>

<style>
  .testimonials-full {
    padding: 2rem 0 8rem;
  }
  .t-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }
  .tf-card {
    padding: 2.4rem 2.6rem;
    border: 1px solid var(--card-border);
    border-radius: 16px;
    background: var(--card);
    backdrop-filter: blur(8px);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.3s;
  }
  .tf-card:hover { border-color: rgba(232,150,10,0.22); }
  .tf-card--full {
    grid-column: 1 / -1;
  }
  .tf-quote-mark {
    font-family: var(--font-display);
    font-size: 4rem;
    line-height: 1;
    color: var(--gold);
    opacity: 0.45;
    margin-bottom: -0.5rem;
  }
  .tf-card p {
    font-size: 0.97rem;
    color: var(--muted);
    line-height: 1.85;
  }
  .tf-author {
    margin-top: 0.8rem;
    padding-top: 1.2rem;
    border-top: 1px solid rgba(232,150,10,0.12);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .tf-name {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--gold);
    letter-spacing: 0.06em;
  }
  .tf-role {
    font-size: 0.75rem;
    color: var(--muted);
    letter-spacing: 0.05em;
  }
  .back-link {
    margin-top: 4rem;
    text-align: center;
  }
  @media (max-width: 768px) {
    .t-grid { grid-template-columns: 1fr; }
    .tf-card--full { grid-column: auto; }
    .testimonials-full { padding: 1rem 0 5rem; }
  }
  @media (max-width: 600px) {
    .tf-card { padding: 1.5rem 1.2rem; }
    .tf-quote-mark { font-size: clamp(2.5rem, 8vw, 4rem); }
    .testimonials-full { padding: 1rem 0 4rem; }
  }
</style>
