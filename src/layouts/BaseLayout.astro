---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Anna Wooten — Integrative Wellness & Transformation" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Outfit:wght@300;400;500&display=swap" rel="stylesheet" />
    <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet" />
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script is:inline src="https://assets.calendly.com/assets/external/widget.js" type="text/javascript"></script>
  </head>
  <body>
    <slot />
    <!-- Background music -->
    <audio id="bg-audio" src="/bg-music.mp3" loop preload="auto"></audio>
    <div id="music-card" class="music-card" style="display:none">
      <button id="music-card-close" class="music-card-close" aria-label="Dismiss">&times;</button>
      <p class="music-card-question">Want the full meditation?</p>
      <a href="https://docs.google.com/forms/d/e/1FAIpQLSeik7iE0JaHG8BqFo7seM37_HhCADFSTDFQJil-HuiV3vzBMQ/viewform" target="_blank" rel="noopener noreferrer" class="music-card-link">Subscribe to my newsletter &#8599;</a>
    </div>
    <button id="music-btn" aria-label="Toggle music" title="Toggle music">
      <svg id="icon-muted" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
        <line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/>
      </svg>
      <svg id="icon-playing" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:none">
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
        <path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
        <path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
      </svg>
    </button>

    <script is:inline>
      var audio = document.getElementById('bg-audio');
      var btn   = document.getElementById('music-btn');
      var iconMuted   = document.getElementById('icon-muted');
      var iconPlaying = document.getElementById('icon-playing');
      var playing = false;

      function setPlaying(on) {
        playing = on;
        iconMuted.style.display   = on ? 'none'  : 'block';
        iconPlaying.style.display = on ? 'block' : 'none';
      }

      var card = document.getElementById('music-card');
      var cardClose = document.getElementById('music-card-close');
      var cardDismissed = localStorage.getItem('musicCardDismissed');

      cardClose.addEventListener('click', function() {
        card.style.display = 'none';
        localStorage.setItem('musicCardDismissed', '1');
      });

      btn.addEventListener('click', function() {
        if (!playing) {
          audio.play().then(function() {
            setPlaying(true);
            if (!cardDismissed) {
              setTimeout(function() { card.style.display = 'block'; }, 1500);
            }
          }).catch(function(){});
        } else {
          audio.pause();
          setPlaying(false);
          card.style.display = 'none';
        }
      });
    </script>
    <script is:inline>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", user => {
          if (!user) {
            window.netlifyIdentity.on("login", () => {
              document.location.href = "/admin/";
            });
          }
        });
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg:          #0d0a1e;
    --text:        #f0eade;
    --gold:        #e8960a;
    --gold-soft:   rgba(232, 150, 10, 0.15);
    --muted:       rgba(240, 234, 222, 0.58);
    --border:      rgba(232, 150, 10, 0.28);
    --card:        rgba(255, 255, 255, 0.04);
    --card-border: rgba(255, 255, 255, 0.09);
    --font-display: 'Cormorant Garamond', serif;
    --font-body:    'Outfit', sans-serif;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    font-weight: 300;
    color: var(--text);
    background-color: var(--bg);
    background-image:
      radial-gradient(ellipse 1px 1px at 63.4% 4.4%, rgba(255,255,255,0.49) 0%, transparent 100%),
      radial-gradient(ellipse 2px 2px at 15.4% 11.8%, rgba(255,255,255,0.72) 0%, transparent 100%),
      radial-gradient(ellipse 1px 1px at 10.3% 42.5%, rgba(255,255,255,0.36) 0%, transparent 100%),
      radial-gradient(ellipse 2px 2px at 24.3% 59.8%, rgba(255,255,255,0.63) 0%, transparent 100%),
      radial-gradient(ellipse 1px 1px at 42.3% 45.1%, rgba(255,255,255,0.49) 0%, transparent 100%),
      radial-gradient(ellipse 1px 1px at 74.8% 17.3%, rgba(255,255,255,0.56) 0%, transparent 100%),
      radial-gradient(ellipse 1px 1px at 16.9% 93.9%, rgba(255,255,255,0.52) 0%, transparent 100%),
      radial-gradient(ellipse 1px 1px at 38.5% 36.5%, rgba(255,255,255,0.52) 0%, transparent 100%),
      radial-gradient(ellipse 1.5px 1.5px at 79.5% 72.1%, rgba(255,255,255,0.62) 0%, transparent 100%),
      radial-gradient(ellipse 1px 1px at 9.6% 30.1%, rgba(255,255,255,0.66) 0%, transparent 100%),
      radial-gradient(ellipse 1px 1px at 57.4% 69.6%, rgba(255,255,255,0.37) 0%, transparent 100%),
      radial-gradient(ellipse 1px 1px at 76.2% 96.6%, rgba(255,255,255,0.78) 0%, transparent 100%),
      radial-gradient(ellipse 1px 1px at 37.5% 22.1%, rgba(255,255,255,0.48) 0%, transparent 100%),
      radial-gradient(ellipse 1px 1px at 60.5% 18.4%, rgba(255,255,255,0.71) 0%, transparent 100%),
      radial-gradient(ellipse 2px 2px at 46.4% 27.9%, rgba(255,255,255,0.81) 0%, transparent 100%),
      radial-gradient(ellipse 1px 1px at 23.1% 33.1%, rgba(255,255,255,0.73) 0%, transparent 100%),
      radial-gradient(ellipse 1px 1px at 24.0% 5.1%, rgba(255,255,255,0.51) 0%, transparent 100%),
      radial-gradient(ellipse 1px 1px at 8.4% 89.7%, rgba(255,255,255,0.63) 0%, transparent 100%),
      radial-gradient(ellipse 1.5px 1.5px at 22.4% 49.9%, rgba(255,255,255,0.79) 0%, transparent 100%),
      radial-gradient(ellipse 2px 2px at 15.7% 15.4%, rgba(255,255,255,0.72) 0%, transparent 100%),
      radial-gradient(ellipse 1.5px 1.5px at 27.2% 58.1%, rgba(255,255,255,0.8) 0%, transparent 100%),
      radial-gradient(ellipse 1px 1px at 10.7% 6.5%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(ellipse 1.5px 1.5px at 78.0% 42.5%, rgba(255,255,255,0.38) 0%, transparent 100%),
      radial-gradient(ellipse 2px 2px at 59.2% 46.9%, rgba(255,255,255,0.48) 0%, transparent 100%),
      radial-gradient(ellipse 2px 2px at 84.6% 3.1%, rgba(255,255,255,0.71) 0%, transparent 100%),
      radial-gradient(ellipse 1px 1px at 74.1% 75.8%, rgba(255,255,255,0.52) 0%, transparent 100%),
      radial-gradient(ellipse 1px 1px at 95.3% 75.1%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(ellipse 2px 2px at 85.6% 30.7%, rgba(255,255,255,0.67) 0%, transparent 100%),
      radial-gradient(ellipse 1px 1px at 90.2% 59.5%, rgba(255,255,255,0.59) 0%, transparent 100%),
      radial-gradient(ellipse 1px 1px at 91.2% 86.4%, rgba(255,255,255,0.77) 0%, transparent 100%),
      radial-gradient(ellipse 2px 2px at 75.5% 14.3%, rgba(255,255,255,0.59) 0%, transparent 100%),
      radial-gradient(ellipse 1px 1px at 17.9% 52.7%, rgba(255,255,255,0.65) 0%, transparent 100%),
      radial-gradient(ellipse 2px 2px at 40.3% 66.5%, rgba(255,255,255,0.54) 0%, transparent 100%),
      radial-gradient(ellipse 2px 2px at 22.6% 14.7%, rgba(255,255,255,0.82) 0%, transparent 100%),
      radial-gradient(ellipse 1.5px 1.5px at 57.3% 25.3%, rgba(255,255,255,0.59) 0%, transparent 100%),
      radial-gradient(ellipse 1px 1px at 7.8% 71.9%, rgba(255,255,255,0.75) 0%, transparent 100%),
      radial-gradient(ellipse 1px 1px at 19.6% 46.4%, rgba(255,255,255,0.79) 0%, transparent 100%),
      radial-gradient(ellipse 1px 1px at 64.6% 53.9%, rgba(255,255,255,0.36) 0%, transparent 100%),
      radial-gradient(ellipse 1px 1px at 48.2% 85.0%, rgba(255,255,255,0.8) 0%, transparent 100%),
      radial-gradient(ellipse 2px 2px at 29.4% 68.9%, rgba(255,255,255,0.72) 0%, transparent 100%),
      radial-gradient(ellipse 1px 1px at 65.5% 48.7%, rgba(255,255,255,0.44) 0%, transparent 100%),
      radial-gradient(ellipse 1px 1px at 95.0% 57.6%, rgba(255,255,255,0.62) 0%, transparent 100%),
      radial-gradient(ellipse 2px 2px at 7.5% 58.1%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(ellipse 1.5px 1.5px at 8.6% 8.5%, rgba(255,255,255,0.78) 0%, transparent 100%),
      radial-gradient(ellipse 2px 2px at 5.8% 9.9%, rgba(255,255,255,0.68) 0%, transparent 100%),
      radial-gradient(ellipse 75% 55% at 15% 65%, rgba(160, 80, 240, 0.28) 0%, transparent 65%),
      radial-gradient(ellipse 60% 45% at 48% 45%, rgba(200, 120, 255, 0.18) 0%, transparent 60%),
      radial-gradient(ellipse 65% 50% at 82% 35%, rgba(80, 120, 255, 0.25) 0%, transparent 62%),
      radial-gradient(ellipse 50% 40% at 72% 12%, rgba(210, 160, 255, 0.15) 0%, transparent 55%),
      radial-gradient(ellipse 100% 80% at 50% 50%, rgba(30, 15, 70, 0.6) 0%, transparent 80%);
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Shared layout primitives ── */
  h1, h2, h3, h4 {
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.2;
  }
  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; display: block; }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 3rem;
  }

  .section-tag {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
  }
  .section-tag.center { text-align: center; }

  .section-title {
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    color: var(--text);
    margin-bottom: 1rem;
  }
  .section-title.center { text-align: center; }

  .divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 1.2rem 0 2rem;
  }
  .divider span:first-child,
  .divider span:last-child {
    flex: 1;
    height: 1px;
    background: var(--gold);
    opacity: 0.35;
    max-width: 60px;
  }
  .divider.center { justify-content: center; }
  .divider.center span:first-child,
  .divider.center span:last-child { max-width: 80px; }
  .diamond { color: var(--gold); font-size: 0.85rem; }

  /* ── Buttons ── */
  .btn {
    display: inline-block;
    padding: 0.85rem 2.2rem;
    border-radius: 9999px;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
    border: none;
  }
  .btn-gold {
    background: var(--gold);
    color: #0d0a1e;
    border: 1px solid var(--gold);
  }
  .btn-gold:hover { opacity: 0.85; }
  .btn-outline {
    background: transparent;
    color: var(--text);
    border: 1px solid rgba(240, 234, 222, 0.35);
  }
  .btn-outline:hover { border-color: var(--gold); color: var(--gold); }

  /* ── Nav ── */
  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.2rem 3rem;
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(13, 10, 30, 0.82);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(232, 150, 10, 0.1);
  }
  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.35rem;
    letter-spacing: 0.03em;
    color: var(--text);
    white-space: nowrap;
  }
  .nav-links {
    display: flex;
    gap: 2rem;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(240, 234, 222, 0.72);
  }
  .nav-links a:hover { color: var(--gold); transition: color 0.3s; }
  .nav-cta {
    padding: 0.5rem 1.3rem;
    background: var(--gold);
    color: #0d0a1e;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
    transition: opacity 0.3s;
  }
  .nav-cta:hover { opacity: 0.85; }

  /* ── Footer ── */
  .footer {
    padding: 2.5rem 3rem;
    text-align: center;
    font-size: 0.78rem;
    color: rgba(240, 234, 222, 0.3);
    letter-spacing: 0.06em;
    border-top: 1px solid rgba(232, 150, 10, 0.1);
  }

  /* ── Page hero (reused across inner pages) ── */
  .page-hero {
    padding: 10rem 3rem 5rem;
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }
  .page-hero h1 { font-size: clamp(2.8rem, 5vw, 4.5rem); margin-bottom: 1.2rem; }
  .page-hero p { color: var(--muted); font-size: 1.05rem; line-height: 1.85; max-width: 580px; margin: 0 auto; }

  @media (max-width: 768px) {
    .nav { padding: 1rem 1.5rem; }
    .nav-links { display: none; }
    .container { padding: 0 1.5rem; }
    .page-hero { padding: 8rem 1.5rem 3rem; }
  }
  /* Music toggle button */
  #music-btn {
    position: fixed;
    bottom: 1.8rem;
    right: 1.8rem;
    z-index: 200;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(13,10,30,0.82);
    border: 1px solid rgba(232,150,10,0.35);
    backdrop-filter: blur(10px);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.3s, transform 0.2s;
    padding: 0;
    color: var(--gold);
  }
  #music-btn:hover { border-color: var(--gold); transform: scale(1.08); }
  #music-btn svg { width: 18px; height: 18px; }
  .music-card {
    position: fixed;
    bottom: 4.8rem;
    right: 1.8rem;
    z-index: 200;
    background: rgba(13,10,30,0.92);
    border: 1px solid rgba(232,150,10,0.35);
    border-radius: 14px;
    padding: 1.1rem 1.4rem 1rem;
    max-width: 220px;
    backdrop-filter: blur(12px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    animation: fadeSlideUp 0.3s ease;
  }
  .music-card::after {
    content: '';
    position: absolute;
    bottom: -6px;
    right: 14px;
    width: 10px;
    height: 10px;
    background: rgba(13,10,30,0.92);
    border-right: 1px solid rgba(232,150,10,0.35);
    border-bottom: 1px solid rgba(232,150,10,0.35);
    transform: rotate(45deg);
  }
  .music-card-close {
    position: absolute;
    top: 0.5rem;
    right: 0.7rem;
    background: none;
    border: none;
    color: rgba(240,234,222,0.35);
    font-size: 1rem;
    cursor: pointer;
    line-height: 1;
    padding: 0;
    transition: color 0.2s;
  }
  .music-card-close:hover { color: var(--gold); }
  .music-card-question {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-style: normal;
    font-weight: 400;
    color: var(--text);
    margin-bottom: 0.5rem;
    line-height: 1.3;
    padding-right: 0.8rem;
  }
  .music-card-link {
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gold);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .music-card-link:hover { opacity: 0.75; }
  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
