---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Anna Wooten — Sessions & Wellness" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body>
    <slot />

    <script is:inline>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", user => {
          if (!user) {
            window.netlifyIdentity.on("login", () => {
              document.location.href = "/admin/";
            });
          }
        });
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    --color-cream: #FBF8F4;
    --color-warm-black: #2A2522;
    --color-accent: #C4956A;
    --color-accent-light: #E8D5C0;
    --color-muted: #8A7E76;
    --font-display: 'Cormorant Garamond', serif;
    --font-body: 'Outfit', sans-serif;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-body);
    font-weight: 300;
    color: var(--color-warm-black);
    background-color: #080412;
    background-image:
      /* Bright galaxy core -- warm gold/amber glow */
      radial-gradient(ellipse 60% 40% at 38% 52%, rgba(220, 160, 80, 0.18) 0%, transparent 60%),
      /* Inner nebula -- soft violet */
      radial-gradient(ellipse 50% 60% at 42% 48%, rgba(160, 80, 220, 0.22) 0%, transparent 55%),
      /* Outer nebula arm -- deep teal */
      radial-gradient(ellipse 80% 40% at 70% 30%, rgba(40, 180, 200, 0.12) 0%, transparent 60%),
      /* Nebula cloud -- rose/magenta */
      radial-gradient(ellipse 55% 45% at 25% 70%, rgba(200, 80, 140, 0.14) 0%, transparent 55%),
      /* Far nebula -- indigo */
      radial-gradient(ellipse 70% 50% at 80% 75%, rgba(80, 60, 200, 0.12) 0%, transparent 60%),
      /* Deep blue cosmic haze */
      radial-gradient(ellipse 100% 80% at 50% 50%, rgba(20, 10, 60, 0.8) 0%, transparent 80%),
      /* Base deep space */
      linear-gradient(135deg, #080412 0%, #0d0820 40%, #060318 100%);
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
  }

  h1, h2, h3, h4 {
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.2;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    display: block;
  }
</style>
